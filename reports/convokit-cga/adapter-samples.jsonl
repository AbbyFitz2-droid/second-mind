{"schema_version": "1.0.0", "record_id": "cga-359c5826c413cf1a", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "143890867.11926.11926", "pair_id": "146743638.12652.12652", "page_id": 1003212, "page_title": "User talk:2005", "annotation_year": "2018", "official_split": "train"}, "participants": [{"id": "speaker_01", "source_id_hash": "22bfb82365316a61", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "b13697a110298cc4", "first_turn_index": 2}], "turns": [{"id": "143890867.11944.11926", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "143890867.11926.11926", "timestamp": 1184126351.0, "text": "No more than two editors advocated deletion.  Greatestrowerever and maybe Kymacpherson.  That's not a clear consensus for deletion.  Cheers,", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "143902946.11991.11991", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "143890867.11944.11926", "timestamp": 1184131325.0, "text": "In the future please don't close Afds when you don't have the courtesy of reading the comments.  All comments favored deletion except two.  Please don't be so careless in the future.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "143945536.12065.12065", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "143902946.11991.11991", "timestamp": 1184153887.0, "text": "That simply isn't true.  If you read the comments, you'll find it's actually 2 keep, 4 transwiki, 2 delete (more or less).  The ''comments'' favour no consensus/transwiki.  The \"votes\" favour delete, but voting is evil, of course...", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "144052463.12169.12169", "turn_index": 4, "speaker_id": "speaker_01", "reply_to": "143890867.11926.11926", "timestamp": 1184189922.0, "text": "Somehow, I suspect you may wish to participate in wiki_link discussion.  Cheers,", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "144065917.12226.12226", "turn_index": 5, "speaker_id": "speaker_02", "reply_to": "144052514.12169.12169", "timestamp": 1184194629.0, "text": "I assume your deliberate lying has a point, but get over it.  Stop bizarrely goin on about transwiking.  That has nothing to do with the afd.  There was a plain consensus for deleting the article. Transwikiing is completely unrelated. Please don't be so deliberately obtuse in the future.  wasting other people's time is simply rude.", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 5}, "prediction_views": {"first_turn": {"turn_ids": ["143890867.11944.11926"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["143890867.11944.11926", "143902946.11991.11991"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["143890867.11944.11926", "143902946.11991.11991", "143945536.12065.12065", "144052463.12169.12169"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_01", "to": "speaker_02", "reply_count": 1}, {"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-e4a041e1a351dbca", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "144643838.1236.1236", "pair_id": "127296808.516.516", "page_id": 10051321, "page_title": "User talk:Billzilla", "annotation_year": "2018", "official_split": "train"}, "participants": [{"id": "speaker_01", "source_id_hash": "307b1f6e52ab5758", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "0f2da37ca1160d20", "first_turn_index": 2}, {"id": "speaker_03", "source_id_hash": "3eb623a69663da1b", "first_turn_index": 3}], "turns": [{"id": "144643838.1260.1236", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "144643838.1236.1236", "timestamp": 1184438740.0, "text": "Please stop removing and altering other editors' comments. What appeared to be valid concern is quickly descending into trolling, and if you continue, you may be blocked from editing. Stop it. -", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "144644837.1330.1330", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "144643838.1260.1236", "timestamp": 1184439120.0, "text": "Well please stop posting incorrect information. If you were right I'd agree with you, and I am NOT trolling.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "144645147.1375.1330", "turn_index": 3, "speaker_id": "speaker_03", "reply_to": "144644837.1330.1330", "timestamp": 1184439240.0, "text": "external_link is trolling, as is removing other people's comments. Look, Wikipedia is built on consensus, and consensus has it that we use American style for American subjects. End of story. Any more complaint about trolling about this topic and I'll report you myself.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "144645449.1479.1479", "turn_index": 4, "speaker_id": "speaker_02", "reply_to": "144643838.1260.1236", "timestamp": 1184439358.0, "text": "Bullshit. I am correcting a simple mistake. If I was trolling I'd be doing damage to the page, yet I  am not. What was written is wrong, simple as that. All I have done is disagree with what was written and written as such. If that's trolling then you are guilty as well. And stop unediting MY page dickhead. Billzilla.", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 4}, "prediction_views": {"first_turn": {"turn_ids": ["144643838.1260.1236"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["144643838.1260.1236", "144644837.1330.1330"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["144643838.1260.1236", "144644837.1330.1330", "144645147.1375.1330"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}, {"id": "speaker_03", "display_name": "Speaker 03", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 2}, {"from": "speaker_03", "to": "speaker_02", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-98a654c94c87230e", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "146743638.12652.12652", "pair_id": "143890867.11926.11926", "page_id": 1003212, "page_title": "User talk:2005", "annotation_year": "2018", "official_split": "train"}, "participants": [{"id": "speaker_01", "source_id_hash": "4dad6b9361db8890", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "b13697a110298cc4", "first_turn_index": 2}], "turns": [{"id": "146743638.12667.12652", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "146743638.12652.12652", "timestamp": 1185277934.0, "text": "I notice that earier that  moved wiki_link to Bill Chen citing wiki_link , then you reverted this change, Bill Chen doesn't commonly go by William, his book is even penned as Bill Chen. From what I read in WP:COMMONNAME PatrikR seems to be correct, Examples given are names such as: *wiki_link (not wiki_link) *wiki_link (not wiki_link) I think this revert may have been a mistake unless you know otherwise? \u25aa\u25e6\u25aa", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "146842219.12874.12874", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "146743638.12667.12652", "timestamp": 1185310317.0, "text": "Chen was known in the poker world as \"William\" for years before he became commonly known as \"Bill\".  I changed it back because incidences online including Usenet are roughly equal, nothing at all like Bill Clinton and William Clinton, and in equal cases using the real name seems the best choice.  (the external_link page is especially pschizo... Willam in the page title, Bill in the page text).  However I suppose the book is the trump card, so using the name on the book is probably best.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "146860774.13072.13072", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "146842696.12874.12874", "timestamp": 1185316241.0, "text": "I see what you saying I just read his pokerstars profile, It struck me when I saw the change because I remember him being called Bill when I watched the last season of high stakes poker, But you seem to have many more years experience in the Poker/Gambling world then I do(I'm still a bit of a newbie), so I wanted to check with you first. BTW as far as the WPT, I was thinking nine that made up final and 6 for the tv table, I read this article that say the WPT Final table is made up of 10 players, with the final six that make it on TV,  I just want to be sure that they are correct, when I update the players infobox stats, thanks \u25aa\u25e6\u25aa", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["146743638.12667.12652"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["146743638.12667.12652", "146842219.12874.12874"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["146743638.12667.12652", "146842219.12874.12874"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-b6b02db78bdadcdb", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "127296808.516.516", "pair_id": "144643838.1236.1236", "page_id": 10051321, "page_title": "User talk:Billzilla", "annotation_year": "2018", "official_split": "train"}, "participants": [{"id": "speaker_01", "source_id_hash": "85afb8d2c129f684", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "0f2da37ca1160d20", "first_turn_index": 2}], "turns": [{"id": "127296808.534.516", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "127296808.516.516", "timestamp": 1177980113.0, "text": "If you have problems with my edits to the 4WD page please let me know, do not just revert the edits.  Although the 4WD article is very accurate the introduction is riddled with errors, which I corrected.  I think it is everyone's best interests to make Wiki pages as accurate as possible and the Four Wheel Drive article is not a gleaming example of this. i.e. All-wheel drive is just a marketing term invented to sell primarily on-road 4WD-type cars This is completely inaccurate AWD is no JUST a marketing term. AWD is very different from 4WD and I explained the differences in my edits. There are also blatant contradictions in this introduction as well. So please instead of immediately reverting my edits tell me what your disagreement is.  If you feel that my edit was inaccurate the please let me know why so this can be resolved. Thank You", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "127331347.862.862", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "127296808.534.516", "timestamp": 1177989161.0, "text": "*Shrug* It *is* just a marketing term. I wish you lot would stop editing it otherwise. Billzilla.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "127772860.903.903", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "127296808.516.516", "timestamp": 1178137463.0, "text": "Although AWD can be considered a form of 4WD it is not the same drive train type as Part-Time 4WD.  So I would have to say calling it just a marketing term is a narrow minded and inaccurate statement.  Even though they are similar you can't just lob them into the same group.  If, as you say, AWD is just a marketing term then taking a turn in a Audi A6 Quattro would produce wheel hop just as taking a turn in a Ford F-250 4x4 with 4WD engaged, which is not the case.  So apparently there is a difference, which would be the center differential in the Audi A6 allowing each wheel to receive a variable amount of power.  Which is not true of 4WD vehicles because a transfer case ,unless a Full-Time 4WD transfer case, will force all wheels to receive 25% of the engine's power.", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["127296808.534.516"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["127296808.534.516", "127331347.862.862"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["127296808.534.516", "127331347.862.862"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-e3048b4c338b0779", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "44473697.13334.13334", "pair_id": "51451175.46444.46444", "page_id": 1122158, "page_title": "User talk:SPUI", "annotation_year": "2018", "official_split": "val"}, "participants": [{"id": "speaker_01", "source_id_hash": "1521bc94d45ffd4b", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "d001fbfe2b4bddb0", "first_turn_index": 2}], "turns": [{"id": "44473697.13344.13334", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "44473697.13334.13334", "timestamp": 1142753593.0, "text": "I don't know what's gotten into you, but the behavior is unacceptable, so You have been wiki_link from editing for wiki_link of Wikipedia. The block is for a period of 1 week. If you wish to make useful contributions, you are welcome to come back after the block expires.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "44474698.13311.13580", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "44473697.13334.13334", "timestamp": 1142754395.0, "text": "Uh... blocked for what?   - )", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "44474912.13327.13327", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "44474698.13311.13580", "timestamp": 1142754542.0, "text": "Personal attacks.  I think your responses to Rschen7754's messages were thoroughly unacceptable, and in addition, your edits that added \"profit\" to wiki_link can't be construed as anything but vandalism.  If you have good explanations for your behavior, please go ahead and give them.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "44475242.13442.13442", "turn_index": 4, "speaker_id": "speaker_02", "reply_to": "44474912.13327.13327", "timestamp": 1142754783.0, "text": "What you call vandalism I call having fun. What you call a personal attack I call a wiki_link.   - )", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 4}, "prediction_views": {"first_turn": {"turn_ids": ["44473697.13344.13334"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["44473697.13344.13334", "44474698.13311.13580"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["44473697.13344.13334", "44474698.13311.13580", "44474912.13327.13327"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_01", "to": "speaker_02", "reply_count": 1}, {"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-48e065bfde57b811", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "195353398.24272.23337", "pair_id": "195353398.23337.23337", "page_id": 113456, "page_title": "Talk:Landmark Worldwide", "annotation_year": "2018", "official_split": "val"}, "participants": [{"id": "speaker_01", "source_id_hash": "1ab2571e90c80d99", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "88f42858109aa196", "first_turn_index": 2}, {"id": "speaker_03", "source_id_hash": "f468c3bc295a747f", "first_turn_index": 3}], "turns": [{"id": "195353398.24282.23337", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "195353398.24272.23337", "timestamp": 1204478636.0, "text": "This item seems to me to be a minor issue which might merit mention in a 500 page book on the subject, is of no significance  to justify its inclusion in an article this size. Organisations of this scale do open and close branch offices from time to time - so what? The operations in France and Sweden were both minute and no doubt marginally viable. Both suffered defamatory attacks from sensationalistic journalists.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "195370870.24434.24434", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "195353398.24282.23337", "timestamp": 1204483867.0, "text": "WP-3O stated inclusion. We've been through this a million times. YOU'RE WRONG. STOP THE VANDALISM.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "195486542.24800.24800", "turn_index": 3, "speaker_id": "speaker_03", "reply_to": "195353398.24272.23337", "timestamp": 1204518954.0, "text": "The references are still bad refs. They are opinion at best. The section should not be in article.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "195534010.24839.24839", "turn_index": 4, "speaker_id": "speaker_02", "reply_to": "195486542.24800.24800", "timestamp": 1204544727.0, "text": "This is getting to be pathetic on your end. You're in denial.", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 4}, "prediction_views": {"first_turn": {"turn_ids": ["195353398.24282.23337"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["195353398.24282.23337", "195370870.24434.24434"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["195353398.24282.23337", "195370870.24434.24434", "195486542.24800.24800"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}, {"id": "speaker_03", "display_name": "Speaker 03", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}, {"from": "speaker_02", "to": "speaker_03", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-0da49ee7fd20622d", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "51451175.46444.46444", "pair_id": "44473697.13334.13334", "page_id": 1122158, "page_title": "User talk:SPUI", "annotation_year": "2018", "official_split": "val"}, "participants": [{"id": "speaker_01", "source_id_hash": "9fc6933782218173", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "d001fbfe2b4bddb0", "first_turn_index": 2}], "turns": [{"id": "51451175.46452.46444", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "51451175.46444.46444", "timestamp": 1146702662.0, "text": "You have been blocked for three hours for incivility. We cannot tolerate these types of edits:", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "51451323.46486.46486", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "51451175.46452.46444", "timestamp": 1146702732.0, "text": "On the contrary, the edits you should not tolerate are the other side preaching their incorrect disambiguation.   -  - wiki_link)", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "51451721.46548.46548", "turn_index": 3, "speaker_id": "speaker_02", "reply_to": "51451175.46444.46444", "timestamp": 1146702902.0, "text": "I have unblocked you to allow you to reply to your RFAr.", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["51451175.46452.46444"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["51451175.46452.46444", "51451323.46486.46486"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["51451175.46452.46444", "51451323.46486.46486"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-0da7f6ad48bb2af7", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "195353398.23337.23337", "pair_id": "195353398.24272.23337", "page_id": 113456, "page_title": "Talk:Landmark Worldwide", "annotation_year": "2018", "official_split": "val"}, "participants": [{"id": "speaker_01", "source_id_hash": "1ab2571e90c80d99", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "88f42858109aa196", "first_turn_index": 2}], "turns": [{"id": "195353398.23351.23337", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "195353398.23337.23337", "timestamp": 1204478636.0, "text": "This article suffers relentlessly from individuals with strong personal viewpoints attempting to drag in material to skew it towards their own point of view (and also suppressing material which does not do so). Wikipedia is not a soapbox, nor is it a forum for expression of opinion.  The NPOV policy lays down that facts about opinion are acceptable, but only where authoritative individuals or clearly defined populations holding those opinions can be identified, and even then, they should only be represented giving due weight to the size of those populations. Much of what is in the article currently is clearly opinion rather than fact. For example:", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "195373039.23575.23575", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "195353398.23351.23337", "timestamp": 1204484466.0, "text": "This article suffers from whitewashing by Spacefarer, DaveApter, Triplejumper, Saladdays, Ratagonia, Gilbertine goldmark, and AlexJackl, among other, all strong LGAT and/or Landmark Education graduates and apologists attempting to create an article devoid of any crtical thought, as their livelihood/reputation likely rides on it. This is known as \"looking good\" in Landroid-speak, and is identified by their \"technology\" as a negative defense and something grads should know by now to be avoided. But the corporation takes presidence over all. Good luck guys. Your edits are denied.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "195600425.23764.23764", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "195534432.23575.23575", "timestamp": 1204568575.0, "text": "Please remain wiki_link and refrain from wiki_link.", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["195353398.23351.23337"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["195353398.23351.23337", "195373039.23575.23575"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["195353398.23351.23337", "195373039.23575.23575"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-fd30504740465e2d", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "241131342.18768.18523", "pair_id": "240149353.16332.16332", "page_id": 10168078, "page_title": "User talk:Orangemike", "annotation_year": "2018", "official_split": "test"}, "participants": [{"id": "speaker_01", "source_id_hash": "8fd8d6381f006364", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "ceb660e909e238f5", "first_turn_index": 2}], "turns": [{"id": "241131342.18781.18523", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "241131342.18768.18523", "timestamp": 1222439337.0, "text": "I want this topic to be UNprotected, so I suggest you do so. Do you wanna go to war with me?", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "241132175.18826.18826", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "241131342.18781.18523", "timestamp": 1222439605.0, "text": "Don't be absurd. Taking it to your talk page.   |", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "241133122.18853.18853", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "241131342.18768.18523", "timestamp": 1222439877.0, "text": "Are you a moron? Did you even bother to read this? I'm going to escalate this. I suggest you learn about me before declaring war. . . .", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 3}, "prediction_views": {"first_turn": {"turn_ids": ["241131342.18781.18523"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["241131342.18781.18523", "241132175.18826.18826"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["241131342.18781.18523", "241132175.18826.18826"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-1e9c82add4fc5b9f", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "465151872.2417.2417", "pair_id": "463673734.2155.2155", "page_id": 11313584, "page_title": "Talk:Zainab Masood", "annotation_year": "2018", "official_split": "test"}, "participants": [{"id": "speaker_01", "source_id_hash": "3a7a0ed5e9787845", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "bc931afe48d43dac", "first_turn_index": 2}, {"id": "speaker_03", "source_id_hash": "6d348f39a2281d48", "first_turn_index": 3}], "turns": [{"id": "465151872.2431.2417", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "465151872.2417.2417", "timestamp": 1323540802.0, "text": "Shouldn't her name be Zainab Yusef and not Zainab Khan?", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "465173799.2454.2454", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "465151872.2431.2417", "timestamp": 1323550352.0, "text": "Does the credits at the end of the episode say ''Zainab Yusef''? No they say ''Zainab Khan'' and Yusef called her ''Mrs. Khan'' during the episode. So no, her name is ''Zainab Khan''.  \u2013", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "465291197.2545.2545", "turn_index": 3, "speaker_id": "speaker_03", "reply_to": "465173799.2454.2454", "timestamp": 1323613888.0, "text": "The Khans are clearly not as traditional as the Masoods, or Afia would have been called Afia Yusef. We already know this! And what GS said. Watch the show properly P \u2013\u2013", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "465344124.2616.2616", "turn_index": 4, "speaker_id": "speaker_01", "reply_to": "465291197.2545.2545", "timestamp": 1323635892.0, "text": "OK. Frst of all,the two of you don't have to be so fucking rude about it because right now, you came off as asswipes. And second, I wasn't watching back then. So watch your tone. Jerks.", "outcome_annotation": {"contains_personal_attack": true}}], "outcome": {"label": "awry", "verified": true, "pair_verified": true, "attack_turn_index": 4}, "prediction_views": {"first_turn": {"turn_ids": ["465151872.2431.2417"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["465151872.2431.2417", "465173799.2454.2454"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["465151872.2431.2417", "465173799.2454.2454", "465291197.2545.2545"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}, {"id": "speaker_03", "display_name": "Speaker 03", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_01", "to": "speaker_03", "reply_count": 1}, {"from": "speaker_02", "to": "speaker_01", "reply_count": 1}, {"from": "speaker_03", "to": "speaker_02", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-cae3d6530321274e", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "240149353.16332.16332", "pair_id": "241131342.18768.18523", "page_id": 10168078, "page_title": "User talk:Orangemike", "annotation_year": "2018", "official_split": "test"}, "participants": [{"id": "speaker_01", "source_id_hash": "1733b26085d811e2", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "cd6e3da48fe088d4", "first_turn_index": 2}], "turns": [{"id": "240149353.16340.16332", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "240149353.16332.16332", "timestamp": 1222053387.0, "text": "I was a bit disgruntled you recently deleted my article on SocialVibe, especially just after it had been patrolled.  I am a user of the site who was interested in its message and felt compelled to look further into it (seriously, my sources are the first couple things that popped up after a google search).  I am a bit confused why a well written and documented article (my first) about an up and coming social networking website with well over 25,000 subscribers and almost 150,000 unique visitors each month (http://www.crunchbase.com/company/socialvibe) is any less relevant than say, Sandis Valters whose brilliantly written article reveals that he is a Latvian guard who plays for ASK Riga.  Having seen such articles before, I did not feel the need to \"justify\" my article; however, I am new at editing/creating wikipedia articles, did I do something incorrectly?  Please respond as I would like to know what I did wrong...", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "240153963.16690.16690", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "240149353.16340.16332", "timestamp": 1222055377.0, "text": "Well, I am not sure if the article meets wiki_link but I think that a claim of 150,000 users a month is a decent claim of notability and there are a few mentions in RS in Google News so could you undelete this article and then send it to AfD where its notability can be better decided. - ''' '''", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "240786321.13311.13311", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "240149353.16332.16332", "timestamp": 1222301064.0, "text": "With regard to the article's lack of notability and a lack of citations, look at wiki_link.  It has only one citation not linking to itself in its entire article (whereas 6 similar sources are used on socialvibe), and it has never logged more than 10,000 unique users/month in its short history (http://www.crunchbase.com/company/bluepulse).  A google search for bluepulse yields 77,000 results, whereas a search for socialvibe gives 146,000.  Bluepulse has big numbers of page views and mobile downloads, but it refuses to tell media outlets how many users acutally use their site.  I like the ideas behind bluepulse's product, but until it is more widely used, it is not yet nearly as notable as socialvibe, nor does their wiki article use nearly as many citations.  And, browsing very quickly through other social networking sites, I am sure that this is not the only one.  Can I put the article back up and go through a standard process for articles for deletion that are not actually spam?", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["240149353.16340.16332"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["240149353.16340.16332", "240153963.16690.16690"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["240149353.16340.16332", "240153963.16690.16690"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_02", "to": "speaker_01", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
{"schema_version": "1.0.0", "record_id": "cga-35635114a5069b97", "metadata": {"data_class": "public_research_dataset", "synthetic": false, "provenance": "convokit_cga_wiki", "pii_status": "source_ids_pseudonymised", "language": "en", "prediction_eligible": true}, "source": {"dataset": "conversations-gone-awry-corpus", "conversation_id": "463673734.2155.2155", "pair_id": "465151872.2417.2417", "page_id": 11313584, "page_title": "Talk:Zainab Masood", "annotation_year": "2018", "official_split": "test"}, "participants": [{"id": "speaker_01", "source_id_hash": "6d348f39a2281d48", "first_turn_index": 1}, {"id": "speaker_02", "source_id_hash": "ed67a81e76302ead", "first_turn_index": 2}, {"id": "speaker_03", "source_id_hash": "41b0330a3ee13ae5", "first_turn_index": 4}], "turns": [{"id": "463673734.2170.2155", "turn_index": 1, "speaker_id": "speaker_01", "reply_to": "463673734.2155.2155", "timestamp": 1322839832.0, "text": "How can anyone be so sure they were married from 1977 until 1983 or whatever it was? Just because she was 15, doesn't mean she married in the year she turned 15, it could have been the year she turned 16. Are we even sure she was born in 1962? How do we know she married Masood in 1983? \u2013\u2013", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "463838506.2299.2299", "turn_index": 2, "speaker_id": "speaker_02", "reply_to": "463673734.2155.2155", "timestamp": 1322926074.0, "text": "I'm not sure about her marriage to Yusef, although I remember them stating when they were about to go travelling (just before she discovered she was pregnant with Kamil) that they had been married 26 years and this was in August 2009.", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "464225744.2389.2389", "turn_index": 3, "speaker_id": "speaker_01", "reply_to": "463838506.2299.2299", "timestamp": 1323099883.0, "text": "Have they ever celebrated a wedding anniversary? I bet someone remembers. \u2013\u2013", "outcome_annotation": {"contains_personal_attack": false}}, {"id": "484672227.2434.2434", "turn_index": 4, "speaker_id": "speaker_03", "reply_to": "463673734.2155.2155", "timestamp": 1333100287.0, "text": "In the divorce papers Masood was reading, it cited that Masood and Zainab married on 28 January 1983. As for her marriage to Yusef I would have said 1977/78 but we can't be sure.", "outcome_annotation": {"contains_personal_attack": false}}], "outcome": {"label": "not_awry", "verified": true, "pair_verified": true, "attack_turn_index": null}, "prediction_views": {"first_turn": {"turn_ids": ["463673734.2170.2155"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "opening_exchange": {"turn_ids": ["463673734.2170.2155", "463838506.2299.2299"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}, "pre_outcome": {"turn_ids": ["463673734.2170.2155", "463838506.2299.2299", "464225744.2389.2389"], "excludes_attack_turn": true, "excluded_target_fields": ["outcome.label", "outcome.attack_turn_index", "turns[].outcome_annotation", "utterance.meta.toxicity", "source.page_id", "source.page_title", "source.annotation_year", "source.official_split", "future_turns"]}}, "cognisyn_bridge": {"people": [{"id": "speaker_01", "display_name": "Speaker 01", "relationship_profile_available": false}, {"id": "speaker_02", "display_name": "Speaker 02", "relationship_profile_available": false}, {"id": "speaker_03", "display_name": "Speaker 03", "relationship_profile_available": false}], "interaction_edges": [{"from": "speaker_01", "to": "speaker_02", "reply_count": 1}], "intentionally_unmapped": ["closeness", "trust", "boundaries", "relationship_goals", "persistent_memory", "real_life_identity"]}}
