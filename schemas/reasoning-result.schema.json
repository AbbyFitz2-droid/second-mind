{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cognisyn.local/schemas/reasoning-result.v1.json",
  "title": "Second Mind structured reasoning result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "generic",
    "contextual",
    "retrievedContext",
    "epistemic",
    "meta"
  ],
  "properties": {
    "generic": { "$ref": "#/$defs/reading" },
    "contextual": {
      "allOf": [
        { "$ref": "#/$defs/reading" },
        {
          "type": "object",
          "required": ["responseOptions", "explanation"],
          "properties": {
            "responseOptions": {
              "type": "array",
              "minItems": 3,
              "items": { "$ref": "#/$defs/responseOption" }
            },
            "explanation": { "type": "string", "minLength": 1 }
          }
        }
      ]
    },
    "retrievedContext": {
      "type": "object",
      "required": ["person", "situations", "claims"],
      "properties": {
        "person": { "type": ["object", "null"] },
        "situations": { "type": "array" },
        "claims": { "type": "array" }
      }
    },
    "epistemic": {
      "type": "object",
      "additionalProperties": false,
      "required": ["facts", "interpretations", "alternatives", "uncertainties"],
      "properties": {
        "facts": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/claim" }
        },
        "interpretations": {
          "type": "array",
          "items": { "$ref": "#/$defs/claim" }
        },
        "alternatives": {
          "type": "array",
          "items": { "type": "string" }
        },
        "uncertainties": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "meta": {
      "type": "object",
      "required": [
        "source",
        "ephemeral",
        "paidApiUsed",
        "intentCategory",
        "explicitIntentDetected"
      ],
      "properties": {
        "source": { "type": "string" },
        "ephemeral": { "type": "boolean" },
        "paidApiUsed": { "type": "boolean" },
        "intentCategory": { "type": "string" },
        "explicitIntentDetected": { "type": "boolean" }
      }
    }
  },
  "$defs": {
    "reading": {
      "type": "object",
      "required": ["label", "interpretation", "draft", "confidence", "basis"],
      "properties": {
        "label": { "type": "string" },
        "interpretation": { "type": "string" },
        "draft": { "type": "string" },
        "confidence": { "type": "string" },
        "basis": { "type": "array" }
      }
    },
    "responseOption": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "label", "text", "why", "recommended"],
      "properties": {
        "id": { "type": "string" },
        "label": { "type": "string" },
        "text": { "type": "string", "minLength": 1 },
        "why": { "type": "string", "minLength": 1 },
        "recommended": { "type": "boolean" }
      }
    },
    "claim": {
      "type": "object",
      "required": [
        "id",
        "type",
        "text",
        "source",
        "confidence",
        "userConfirmation"
      ],
      "properties": {
        "id": { "type": "string" },
        "type": { "type": "string" },
        "text": { "type": "string" },
        "source": { "type": "string" },
        "confidence": { "type": "string" },
        "userConfirmation": { "type": "string" }
      }
    }
  }
}
