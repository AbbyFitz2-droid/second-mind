# Keep this key on the server. Never expose it in browser code.
OPENAI_API_KEY=

# Terra is the balanced GPT-5.6 production model.
OPENAI_MODEL=gpt-5.6-terra
OPENAI_TRANSCRIBE_MODEL=gpt-4o-mini-transcribe

# Paid API calls are blocked unless this is deliberately changed to true.
PAID_API_ENABLED=false

# When true, the app remains usable without paid API access.
DEMO_MODE=true
PORT=3000
